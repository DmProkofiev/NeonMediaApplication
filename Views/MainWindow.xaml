<Window x:Class="NeonMediaApplication.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeonMediaApplication.Views" 
        xmlns:ViewModels="clr-namespace:NeonMediaApplication.ViewModels"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        xmlns:converters="clr-namespace:NeonMediaApplication.Converters"
        Title="Neon Media" Height="600" Width="900" MinHeight="400" MinWidth="700" WindowStartupLocation="CenterScreen" >
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid x:Name="MainSpace">
        <Grid.RowDefinitions>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="MainBoard" Grid.Row="1" Grid.Column="1" Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Neon Media Player" FontFamily="Times New Roman" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center"/>
            <Button Grid.Row="3" Grid.Column="2" Command="{Binding OpenFileCommand}" Content="Открыть Файл" FontFamily="Times New Roman" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" Padding="8,1,8,1"/>
        </Grid>
        <Grid x:Name="MainPlayer" Grid.Row="1" Grid.Column="1" Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
            </Grid.ColumnDefinitions>
            <vlc:VideoView x:Name="VideoView" Grid.Row="1" Grid.Column="1" MediaPlayer="{Binding MediaPlayer}" />
            <Grid x:Name="DurationLine" Grid.Row="2" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding CurrentMedia.Duration, TargetNullValue=00:00:00, StringFormat=hh\\:mm\\:ss}" Margin="3,0,3,0" VerticalAlignment="Center" FontFamily="Times New Roman" FontWeight="Bold"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="{Binding DurationSeconds}" Value="{Binding SeekPosition, Mode=TwoWay}" LargeChange="5" SmallChange="1" Margin="5,0,5,0" Background="White"/>
                <TextBlock Grid.Column="2" Text="{Binding CurrentPosition, TargetNullValue=00:00:00, StringFormat=hh\\:mm\\:ss}" Margin="3,0,3,0" VerticalAlignment="Center" FontFamily="Times New Roman" FontWeight="Bold"/>
            </Grid>
            <Grid x:Name="RemoteControl" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Width="Auto">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="5,5,5,5" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="30" MaxHeight="35">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Source="{Binding CurrentMedia.CoverArt}"  Grid.Column="0" Margin="5,5,5,5" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentMedia.Album, TargetNullValue=Альбом}" Grid.Column="1" Margin="5,5,5,5" TextWrapping="Wrap" FontFamily="Times New Roman" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentMedia.Title, TargetNullValue=Исполнитель}" Grid.Column="2" Margin="5,5,5,5" TextWrapping="Wrap" FontFamily="Times New Roman" HorizontalAlignment="Right"/>
                </Grid>
                <Button Content="Pause" Command="{Binding PauseCommand}" Width="60" Margin="2" Grid.Column="1"/>
                <Button Content="Play" Command="{Binding PlayCommand}" Width="60" Margin="2" Grid.Column="2"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Width="60" Margin="2" Grid.Column="3"/>
                <Slider Width="150" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay}" Margin="5,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="4"/>
            </Grid>
        </Grid>
    </Grid>
    
</Window>
