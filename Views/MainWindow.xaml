<Window x:Class="NeonMediaApplication.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeonMediaApplication.Views" 
        xmlns:ViewModels="clr-namespace:NeonMediaApplication.ViewModels"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="Neon Media" Height="500" Width="800" MinHeight="250" MinWidth="400" >

    <Grid x:Name="MainSpace">
        <Grid.RowDefinitions>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="1"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="MainBoard" Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1"/>
                <RowDefinition Height="75"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Neon Media Player" FontFamily="Times New Roman" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center"/>
            <Button Grid.Row="4" Grid.Column="3" Command="{Binding OpenFileCommand}" Content="Открыть Файл" FontFamily="Times New Roman" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" Padding="8,1,8,1"/>
        </Grid>
        
        <vlc:VideoView x:Name="VideoView" Grid.Row="1" Grid.Column="1" MediaPlayer="{Binding Media}" />
        
        <Grid x:Name="DurationLine" Grid.Row="2" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Minimum="0" Value="{Binding CurrentPosition.TotalSeconds, Mode=OneWay}" LargeChange="5" SmallChange="1"/>
            <TextBlock Grid.Column="1" Text="{Binding CurrentMedia.Duration, TargetNullValue=00:00:00, FallbackValue=00:00:00}" Margin="3,0,3,0" VerticalAlignment="Center" FontFamily="Times New Roman" FontWeight="Bold"/>
        </Grid>
        <Grid x:Name="RemoteControl" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Width="Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="5,5,5,5" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Source="{Binding CurrentMedia.CoverArt}"  Grid.Column="0"/>
                <TextBlock Text="{Binding CurrentMedia.Album, TargetNullValue=Альбом}" Grid.Column="1"/>
                <TextBlock Text="{Binding CurrentMedia.Title, TargetNullValue=Исполнитель}" Grid.Column="2"/>
            </Grid>
            <Button Content="Play" Command="{Binding PlayCommand}" Width="60" Margin="2" Grid.Column="1"/>
            <Button Content="Pause" Command="{Binding PauseCommand}" Width="60" Margin="2" Grid.Column="2"/>
            <Button Content="Stop" Command="{Binding StopCommand}" Width="60" Margin="2" Grid.Column="3"/>
            <Slider Width="150" Minimum="0" Maximum="100" Value="{Binding Volume}" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="4"/>
            <TextBlock Text="{Binding CurrentMedia.PositionText}" Margin="10,0,10,0" VerticalAlignment="Center" Grid.Column="5"/>
        </Grid>
    </Grid>
</Window>
